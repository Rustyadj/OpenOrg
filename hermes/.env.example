# Hermes-Lisa environment variables
# Copy to .env and fill in real values — never commit .env

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Open WebUI secrets (generate with: openssl rand -hex 32)
HERMES_SECRET_KEY=
HERMES_DASH_SECRET_KEY=

# OpenOrg memory service (matches docker-compose.yml AUTH_TOKEN)
MEMORY_SERVICE_TOKEN=openclaw-memory-secret

# Composio (get from composio.dev)
COMPOSIO_API_KEY=
