{
  "name": "openclaw-memory-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "test": "DATABASE_URL=postgresql://openclaw:openclaw@localhost:5435/openclaw_test npm run migrate --silent && DATABASE_URL=postgresql://openclaw:openclaw@localhost:5435/openclaw_test NODE_ENV=test jest --passWithNoTests --detectOpenHandles"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "bullmq": "^5.3.3",
    "fastify": "^4.26.2",
    "ioredis": "^5.3.2",
    "neo4j-driver": "^5.18.0",
    "openai": "^4.38.0",
    "pg": "^8.11.5",
    "pgvector": "^0.2.0",
    "pino": "^8.19.0",
    "uuid": "^9.0.1",
    "voyageai": "^0.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 30000,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "maxWorkers": 1,
    "setupFilesAfterEnv": [
      "<rootDir>/tests/openai.mock.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  }
}
